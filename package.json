    "@tsparticles/slim": "^3.9.1",
    "@uploadcare/blocks": "^0.50.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.0",
    "lint-staged": "^16.3.2",
    "lucide-react": "^0.576.0",
    "motion": "^12.35.0",
    "next": "16.1.6",
